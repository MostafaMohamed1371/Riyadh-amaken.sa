{
	"info": {
		"_postman_id": "riyadh-amaken-api",
		"name": "Riyadh Amaken API",
		"description": "API collection for Riyadh Amaken. All endpoints except Register and Login require authentication: call Login or Register first, copy data.token into the auth_token variable, then use other requests (Bearer token is sent automatically).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000/api"
		},
		{
			"key": "slider_id",
			"value": "1"
		},
		{
			"key": "category_id",
			"value": "1"
		},
		{
			"key": "gallery_id",
			"value": "1"
		},
		{
			"key": "activity_id",
			"value": "1"
		},
		{
			"key": "event_id",
			"value": "1"
		},
		{
			"key": "auth_token",
			"value": ""
		},
		{
			"key": "user_id",
			"value": "1"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"auth": {"type": "noauth"},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json", "type": "text"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/register",
							"host": ["{{base_url}}"],
							"path": ["register"]
						},
						"description": "Register a new user. Returns token in response; save to auth_token for authenticated requests."
					}
				},
				{
					"name": "Login",
					"request": {
						"auth": {"type": "noauth"},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json", "type": "text"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Login. Returns token in response.data.token; set auth_token and use header: Authorization: Bearer {{auth_token}} for Logout and Get User."
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{auth_token}}", "type": "text"},
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"url": {
							"raw": "{{base_url}}/logout",
							"host": ["{{base_url}}"],
							"path": ["logout"]
						},
						"description": "Revoke current token. Requires Bearer token in Authorization header."
					}
				},
				{
					"name": "Get current user",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Authorization", "value": "Bearer {{auth_token}}", "type": "text"},
							{"key": "Accept", "value": "application/json", "type": "text"}
						],
						"url": {
							"raw": "{{base_url}}/user",
							"host": ["{{base_url}}"],
							"path": ["user"]
						},
						"description": "Get authenticated user. Requires Bearer token."
					}
				}
			]
		},
		{
			"name": "Sliders",
			"item": [
				{
					"name": "List Sliders",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/sliders?per_page=15",
							"host": ["{{base_url}}"],
							"path": ["sliders"],
							"query": [
								{"key": "per_page", "value": "15", "description": "Items per page (max 100)"}
							]
						},
						"description": "Get paginated list of sliders"
					}
				},
				{
					"name": "Get Slider",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/sliders/{{slider_id}}",
							"host": ["{{base_url}}"],
							"path": ["sliders", "{{slider_id}}"]
						},
						"description": "Get single slider by ID"
					}
				},
				{
					"name": "Create Slider",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "title", "value": "Welcome Slider", "type": "text"},
								{"key": "description", "value": "Slider description", "type": "text"},
								{"key": "image", "type": "file", "src": ""}
							]
						},
						"url": {
							"raw": "{{base_url}}/sliders",
							"host": ["{{base_url}}"],
							"path": ["sliders"]
						},
						"description": "Create slider. Use form-data; image is optional file."
					}
				},
				{
					"name": "Update Slider",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated Title\",\n  \"description\": \"Updated description\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/sliders/{{slider_id}}",
							"host": ["{{base_url}}"],
							"path": ["sliders", "{{slider_id}}"]
						},
						"description": "Update slider. For new image use form-data with image file."
					}
				},
				{
					"name": "Delete Slider",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/sliders/{{slider_id}}",
							"host": ["{{base_url}}"],
							"path": ["sliders", "{{slider_id}}"]
						},
						"description": "Delete slider. Returns 200 with { \"success\": true, \"message\": \"Slider deleted successfully.\" }"
					}
				}
			]
		},
