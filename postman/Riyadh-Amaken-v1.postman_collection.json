    {
      "name": "Auth (api)",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"your-password\"\n}"
            },
            "url": "{{legacy_base_url}}/login"
          }
        },
        {
          "name": "User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": "{{legacy_base_url}}/user"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": "{{legacy_base_url}}/logout"
          }
        }
      ]
    },
    {
      "name": "Schedule — Bearer (Sanctum)",
      "item": [
        {
          "name": "POST Add to schedule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"place\",\n  \"id\": 1\n}"
            },
            "url": "{{base_url}}/schedule"
          }
        },
        {
          "name": "PUT Reorder",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order\": [1, 2]\n}"
            },
            "url": "{{base_url}}/schedule/reorder"
          }
        },
        {
          "name": "DELETE Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": "{{base_url}}/schedule/{{schedule_item_id}}"
          }
        }
      ]
    },
